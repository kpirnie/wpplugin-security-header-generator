#: source/work/doc.php:418
msgid "Permissions Policy Tab"
msgstr ""

#: source/work/doc.php:419
msgid "Permissions Policy (formerly Feature Policy) controls which browser features and APIs your website and embedded content can use. This prevents malicious scripts from accessing sensitive features like camera, microphone, or geolocation."
msgstr ""

#: source/work/doc.php:422
msgid "Configure Permissions Policy"
msgstr ""

#: source/work/doc.php:425
msgid "Enable this to control browser feature permissions. For each feature, you can choose:"
msgstr ""

#: source/work/doc.php:427
msgid "Block this feature completely"
msgstr ""

#: source/work/doc.php:428
msgid "Allow from any domain (least secure)"
msgstr ""

#: source/work/doc.php:429
msgid "Only allow from your own domain (recommended)"
msgstr ""

#: source/work/doc.php:430
msgid "Allow from specific domains you list"
msgstr ""

#: source/work/doc.php:434
msgid "If you select \"Source\", enter full URLs with protocol: <code>https://example.com https://trusted-site.com</code>"
msgstr ""

#: source/work/doc.php:442
msgid "Choose whether to apply Permissions Policy to your WordPress admin area as well as the public site."
